{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/build-api.mjs",
  "outputDirectory": "public",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "functions": {
    "api-build/*.mjs": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api-build/:path*.mjs" }
  ]
}
